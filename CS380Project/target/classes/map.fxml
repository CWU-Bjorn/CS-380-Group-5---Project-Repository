<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="602.0" prefWidth="42.0" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="UserInterface.MapController">
   <children>
      <ImageView fitHeight="550.0" fitWidth="504.0" layoutY="-1.0" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@Map.png" />
         </image>
      </ImageView>
      <Button layoutY="538.0" mnemonicParsing="false" onAction="#onEnterConflictClick" prefHeight="30.0" prefWidth="126.0" styleClass="map-button" text="ToGameplay" textFill="WHITE">
         <font>
            <Font name="Candara" size="16.0" />
         </font></Button>
      <Button layoutY="505.0" mnemonicParsing="false" onAction="#onBackToMenuClick" prefHeight="30.0" prefWidth="126.0" styleClass="map-button" text="BackToMenu" textFill="WHITE">
         <font>
            <Font name="Candara" size="16.0" />
         </font></Button>
      <Button layoutX="227.0" layoutY="363.0" mnemonicParsing="false" onAction="#onEnterConflictClick" prefHeight="50.0" prefWidth="50.0" style="-fx-background-radius: 15;" styleClass="level-button" text="level1" textFill="#e62929" />
      <Button layoutX="60.0" layoutY="362.0" mnemonicParsing="false" onAction="#onShopClick" prefHeight="50.0" prefWidth="50.0" style="-fx-background-radius: 15;" styleClass="shop-button" text="level1" textFill="#290dfd" />
      <Button layoutX="195.0" layoutY="226.0" mnemonicParsing="false" onAction="#onPuzzleClick" prefHeight="50.0" prefWidth="50.0" style="-fx-background-radius: 15;" styleClass="level-button" text="level1" textFill="#e62929" />
      <Button layoutX="91.0" layoutY="92.0" mnemonicParsing="false" onAction="#onEnterConflictClick" prefHeight="50.0" prefWidth="50.0" style="-fx-background-radius: 15;" styleClass="level-button" text="level1" textFill="#e62929" />
      <Button layoutX="431.0" layoutY="24.0" mnemonicParsing="false" onAction="#completion" prefHeight="50.0" prefWidth="50.0" style="-fx-background-radius: 15;" styleClass="end-button" text="Finish" textFill="black" />      <TextArea fx:id="textAreaForInventory" editable="false" layoutX="126.0" layoutY="505.0" prefHeight="96.0" prefWidth="377.0">
         <font>
            <Font name="Cambria" size="16.0" />
         </font></TextArea>
      <Button layoutY="570.0" mnemonicParsing="false" onAction="#buttonActionClick" prefHeight="30.0" prefWidth="126.0" styleClass="map-button" text="Check Inventory" />
      <Button layoutX="182.0" layoutY="24.0" mnemonicParsing="false" onAction="#keyChecking" prefHeight="50.0" prefWidth="67.0" style="-fx-background-radius: 15;" styleClass="mapDoor-button" text="Door" />
      <ImageView fitHeight="30.0" fitWidth="22.0" layoutX="202.0" layoutY="34.0" onMouseClicked="#keyChecking" pickOnBounds="true" preserveRatio="true">
         <image>
            <Image url="@Keyhole.png" />
         </image>
      </ImageView>
   </children>
</AnchorPane>
