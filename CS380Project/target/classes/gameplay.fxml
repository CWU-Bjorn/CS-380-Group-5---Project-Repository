<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane prefHeight="600.0" prefWidth="800.0" style="-fx-background-color: #d1d8e0; -fx-font-family: 'Courier New', monospace;" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="UserInterface.GameplayController">

    <top>
        <HBox alignment="CENTER" prefHeight="80.0" spacing="10.0">
            <padding>
                <Insets bottom="10.0" left="20.0" right="20.0" top="20.0" />
            </padding>
            <children>
                <Button fx:id="exitButton" mnemonicParsing="false" onAction="#onExitGameplayLoop" styleClass="exit-button" text="RUN AWAY">
               <font>
                  <Font name="Candara" size="12.0" />
               </font></Button>
            <Label fx:id="enemyNameDisp" text="Enemy Name" />
            <Label fx:id="enemyAttackPointDisp" text="Enemy Attack Point" />
            <Label fx:id="enemyHPDisp" text="Enemy Health" />

                <Region HBox.hgrow="ALWAYS" />

                <VBox alignment="CENTER_LEFT" spacing="5.0" style="-fx-background-color: #1e90ff; -fx-border-color: black; -fx-border-width: 2; -fx-padding: 10;">
                    <children>
                        <Label fx:id="playerNameLabel" style="-fx-font-weight: bold; -fx-font-size: 14;" text="Player       Lv. 25">
                     <font>
                        <Font name="Candara" size="12.0" />
                     </font></Label>
                        <HBox alignment="CENTER_LEFT" spacing="8.0">
                            <children>
                                <Label style="-fx-font-weight: bold; -fx-font-size: 12;" text="HP:" />
                                <ProgressBar fx:id="healthBar" prefHeight="15.0" prefWidth="140.0" progress="0.75" style="-fx-accent: #2ecc71; -fx-control-inner-background: #eeeeee;" />
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </HBox>
    </top>

    <center>
        <StackPane>
            <children>
                <Label style="-fx-text-fill: #777777; -fx-font-size: 16;" text="[ Sprite Area ]">
               <font>
                  <Font name="Cambria" size="12.0" />
               </font></Label>
            </children>
        </StackPane>
    </center>

    <bottom>
        <HBox prefHeight="230.0" prefWidth="800.0" style="-fx-background-color: #1e90ff; -fx-border-color: black; -fx-border-width: 3 0 0 0;">
            <children>

                <TextArea fx:id="dialogueText" editable="false" maxWidth="Infinity" style="-fx-font-size: 16; -fx-padding: 20; -fx-line-spacing: 4;" wrapText="true" HBox.hgrow="ALWAYS">
               <font>
                  <Font name="Cambria" size="14.0" />
               </font></TextArea>

                <GridPane hgap="10.0" prefWidth="300.0" style="-fx-border-color: black; -fx-border-width: 0 0 0 3; -fx-padding: 15;" vgap="10.0">
                    <columnConstraints>
                        <ColumnConstraints hgrow="SOMETIMES" percentWidth="50.0" />
                        <ColumnConstraints hgrow="SOMETIMES" percentWidth="50.0" />
                    </columnConstraints>
                    <rowConstraints>
                        <RowConstraints percentHeight="50.0" vgrow="SOMETIMES" />
                        <RowConstraints percentHeight="50.0" vgrow="SOMETIMES" />
                    </rowConstraints>
                    <children>
                        <Button fx:id="attackAction" maxHeight="Infinity" maxWidth="Infinity" mnemonicParsing="false" onAction="#attack" styleClass="action-button" text="Attack" textFill="WHITE">
                     <font>
                        <Font name="Candara" size="12.0" />
                     </font></Button>
                        <Button fx:id="shieldAction" maxHeight="Infinity" maxWidth="Infinity" mnemonicParsing="false" onAction="#shield" styleClass="action-button" text="Shield" GridPane.columnIndex="1" />
                        <Button fx:id="healAction" maxHeight="Infinity" maxWidth="Infinity" mnemonicParsing="false" onAction="#health" styleClass="action-button" text="Heal" GridPane.rowIndex="1" />
                        <Button fx:id="fleeAction" maxHeight="Infinity" maxWidth="Infinity" mnemonicParsing="false" onAction="#flee" styleClass="action-button" text="Flee" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                    </children>
                </GridPane>

            </children>
        </HBox>
    </bottom>
</BorderPane>
