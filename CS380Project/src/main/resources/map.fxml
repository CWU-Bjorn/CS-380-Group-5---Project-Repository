            <Font name="Candara" size="16.0" />
         </font></Button>
      <Button layoutY="505.0" mnemonicParsing="false" onAction="#onBackToMenuClick" prefHeight="30.0" prefWidth="126.0" styleClass="map-button" text="BackToMenu" textFill="WHITE">
         <font>
            <Font name="Candara" size="16.0" />
         </font></Button>
      <Button layoutX="227.0" layoutY="365.0" mnemonicParsing="false" onAction="#onEnterLocationClick" prefHeight="50.0" prefWidth="50.0" style="-fx-background-radius: 15;" styleClass="level-button" text="level1" textFill="#e62929" />
      <Button layoutX="60.0" layoutY="365.0" mnemonicParsing="false" onAction="#onShopClick" prefHeight="50.0" prefWidth="50.0" style="-fx-background-radius: 15;" styleClass="shop-button" text="level1" textFill="#290dfd" />
      <Button layoutX="195.0" layoutY="228.0" mnemonicParsing="false" onAction="#onEnterLocationClick" prefHeight="50.0" prefWidth="50.0" style="-fx-background-radius: 15; -fx-background-color: #e62929;" text="level1" textFill="#e62929" />
      <Button layoutX="93.0" layoutY="93.0" mnemonicParsing="false" onAction="#onEnterLocationClick" prefHeight="50.0" prefWidth="50.0" style="-fx-background-radius: 15;" styleClass="level-button" text="level1" textFill="#e62929" />
      <Button layoutX="431.0" layoutY="24.0" mnemonicParsing="false" prefHeight="50.0" prefWidth="50.0" style="-fx-background-radius: 15;" styleClass="end-button" text="level1" textFill="#f7f00f" />
      <TextArea fx:id="textAreaForInventory" editable="false" layoutX="126.0" layoutY="505.0" prefHeight="96.0" prefWidth="377.0">
         <font>
            <Font name="Cambria" size="16.0" />
         </font></TextArea>
      <Button layoutY="570.0" mnemonicParsing="false" onAction="#buttonActionClick" prefHeight="30.0" prefWidth="126.0" styleClass="map-button" text="Check Inventory" />
      <Button layoutX="182.0" layoutY="24.0" mnemonicParsing="false" onAction="#keyChecking" prefHeight="50.0" prefWidth="67.0" text="Door" />
