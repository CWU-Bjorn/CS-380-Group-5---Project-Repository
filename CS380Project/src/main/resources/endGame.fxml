<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="497.0" prefWidth="601.0" style="-fx-background-color: #1c1f26;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="UserInterface.EndGameController">

    <children>

        <!-- TITLE -->
        <Label layoutX="165.0" layoutY="87.0" text="🏆 YOU WIN!" textFill="#f5c542">

            <font>
                <Font name="Impact" size="55" />
            </font>
        </Label>

        <!-- SUBTITLE -->
        <Label layoutX="179.0" layoutY="180.0" text="You completed the adventure!" textFill="#d0d0d0">

            <font>
                <Font size="18" />
            </font>
        </Label>

        <!-- STATS BOX -->
        <VBox layoutX="208.0" layoutY="248.0" spacing="10" style="-fx-background-color: #2a2f3a;                      -fx-padding: 20;                      -fx-background-radius: 10;">

            <Label text="Final Stats:" textFill="white">
                <font>
                    <Font size="18" />
                </font>
            </Label>

            <Label fx:id="statsLabel" textFill="#ffffff">
                <font>
                    <Font size="16" />
                </font>
            </Label>

        </VBox>

        <!-- RETURN BUTTON -->
        <Button layoutX="148.0" layoutY="456.0" onAction="#onReturnMenuClick" prefWidth="150" style="-fx-background-color: #3b82f6;                        -fx-text-fill: white;                        -fx-font-size: 14;                        -fx-background-radius: 8;" text="Return to Map" />

        <!-- EXIT BUTTON -->
        <Button layoutX="331.0" layoutY="456.0" onAction="#onExitClick" prefWidth="150" style="-fx-background-color: #ef4444;                        -fx-text-fill: white;                        -fx-font-size: 14;                        -fx-background-radius: 8;" text="Exit Game" />

    </children>

</AnchorPane>
